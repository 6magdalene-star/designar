<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Praca — Lwówek Śląski</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap');

:root {
  --bg: #f5f2eb;
  --card: #fff;
  --ink: #0d1117;
  --muted: #6b6355;
  --line: #ddd8ce;
  --rust: #c0440a;
  --rust2: #e05c1a;
  --green: #1e6e3e;
  --steel: #2d4a6e;
  --r: 10px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--ink); min-height: 100vh; }

.hero { background: var(--ink); color: #f5f2eb; padding: 24px 18px 20px; }
.hero-eye { font-size: 0.68rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--rust2); margin-bottom: 6px; }
.hero h1 { font-family: 'Syne', sans-serif; font-size: clamp(1.4rem, 6vw, 2rem); font-weight: 800; letter-spacing: -.02em; line-height: 1.1; margin-bottom: 8px; }
.hero h1 em { font-style: normal; color: var(--rust2); }
.hero p { font-size: .82rem; color: #999; line-height: 1.5; }

.chips { display: flex; flex-wrap: wrap; gap: 6px; padding: 12px 18px; background: #161b24; border-top: 1px solid #222; }
.chip { font-size: .7rem; font-weight: 600; padding: 3px 9px; border-radius: 20px; }
.cr { background: rgba(192,68,10,.25); color: #e87040; }
.cs { background: rgba(45,74,110,.4); color: #7eb3e8; }
.cg { background: rgba(30,110,62,.3); color: #5ec98a; }

main { padding: 18px 16px 60px; max-width: 680px; margin: 0 auto; }

.api-row { display: flex; gap: 8px; margin-bottom: 16px; }
.api-row input {
  flex: 1; font-family: 'DM Sans', sans-serif; font-size: .88rem;
  padding: 10px 13px; border: 1.5px solid var(--line); border-radius: var(--r);
  background: var(--card); color: var(--ink); outline: none; transition: border-color .2s;
}
.api-row input:focus { border-color: var(--steel); }
.btn-sm {
  font-family: 'DM Sans', sans-serif; font-size: .8rem; font-weight: 600;
  padding: 10px 12px; border-radius: var(--r); border: 1.5px solid var(--line);
  background: var(--card); color: var(--muted); cursor: pointer; white-space: nowrap;
  transition: all .2s;
}
.btn-sm:hover { border-color: var(--steel); color: var(--steel); }

.btn-search {
  width: 100%; font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 800;
  letter-spacing: .02em; padding: 15px; border: none; border-radius: var(--r);
  background: var(--rust); color: #fff; cursor: pointer; transition: background .2s, transform .1s;
  margin-bottom: 20px;
}
.btn-search:hover { background: var(--rust2); }
.btn-search:active { transform: scale(.99); }
.btn-search:disabled { background: #aaa; cursor: not-allowed; }

.status { display: flex; align-items: center; gap: 9px; font-size: .83rem; color: var(--muted); margin-bottom: 14px; min-height: 22px; }
.spinner { width: 13px; height: 13px; border: 2px solid var(--line); border-top-color: var(--rust); border-radius: 50%; animation: spin .7s linear infinite; flex-shrink: 0; }
@keyframes spin { to { transform: rotate(360deg); } }

.error-box { background: #fff0ec; border: 1.5px solid #f5c2ad; border-radius: var(--r); color: #9b3015; font-size: .84rem; padding: 11px 14px; margin-bottom: 14px; }

/* Nagłówek wyników */
.results-hd {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px; padding-bottom: 10px; border-bottom: 2px solid var(--ink);
}
.results-hd h2 { font-family: 'Syne', sans-serif; font-size: .72rem; font-weight: 800; text-transform: uppercase; letter-spacing: .12em; color: var(--muted); }
.badge { background: var(--rust); color: #fff; font-size: .7rem; font-weight: 700; padding: 2px 9px; border-radius: 20px; }

/* Karta oferty — PROSTA */
.offer {
  background: var(--card);
  border: 1.5px solid var(--line);
  border-radius: var(--r);
  padding: 15px 16px;
  margin-bottom: 10px;
  transition: border-color .2s, box-shadow .2s;
}
.offer:hover { border-color: var(--rust); box-shadow: 0 2px 10px rgba(192,68,10,.08); }

.offer-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 4px; }
.offer-title { font-family: 'Syne', sans-serif; font-size: .95rem; font-weight: 700; color: var(--ink); line-height: 1.2; flex: 1; }
.src { font-size: .65rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; padding: 3px 7px; border-radius: 4px; background: #f0ede6; color: var(--muted); border: 1px solid var(--line); flex-shrink: 0; }

.offer-company { font-size: .85rem; font-weight: 600; color: var(--steel); margin-bottom: 7px; }

.pills { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
.pill { font-size: .72rem; font-weight: 600; padding: 3px 9px; border-radius: 5px; }
.p-loc  { background: #eef3fa; color: var(--steel); }
.p-car  { background: #fef0e8; color: var(--rust); border: 1px solid #f5c9b0; }
.p-pay  { background: #edf7f1; color: var(--green); }
.p-date { background: #f5f2eb; color: var(--muted); border: 1px solid var(--line); }
.p-del  { background: #f5f2eb; color: var(--muted); border: 1px solid var(--line); }
.p-train{ background: #eef3fa; color: var(--steel); }

/* LINK — główny przycisk */
.offer-link {
  display: block;
  text-align: center;
  background: var(--ink);
  color: #f5f2eb;
  font-family: 'Syne', sans-serif;
  font-size: .82rem;
  font-weight: 700;
  letter-spacing: .03em;
  padding: 10px;
  border-radius: 7px;
  text-decoration: none;
  transition: background .15s;
  margin-top: 4px;
}
.offer-link:hover { background: var(--rust); }
.offer-link-missing {
  display: block;
  text-align: center;
  background: #f0ede6;
  color: var(--muted);
  font-size: .78rem;
  padding: 9px;
  border-radius: 7px;
  margin-top: 4px;
  border: 1px dashed var(--line);
}

.offer-why { font-size: .78rem; color: var(--rust); font-weight: 600; margin-bottom: 8px; }

/* Podsumowanie */
.summary { background: var(--steel); color: #dce8f5; border-radius: var(--r); padding: 14px 16px; font-size: .84rem; line-height: 1.6; margin-bottom: 18px; }
.tip { border-left: 3px solid var(--rust); padding: 11px 13px; background: #fef6f2; border-radius: 0 var(--r) var(--r) 0; font-size: .82rem; color: var(--muted); line-height: 1.55; margin-top: 16px; }
.tip strong { color: var(--ink); }

.no-results { text-align: center; padding: 40px 20px; color: var(--muted); font-size: .88rem; line-height: 1.6; }
</style>
</head>
<body>

<header>
  <div class="hero">
    <div class="hero-eye">Dolny Śląsk · Lwówek Śląski i okolice</div>
    <h1>Praca z <em>autem służbowym</em></h1>
    <p>Serwisant · Instalator · Technik terenowy<br>Tylko świeże oferty · Tylko z autem · Bez wymaganego doświadczenia</p>
  </div>
  <div class="chips">
    <span class="chip cr">🚗 Auto służbowe</span>
    <span class="chip cr">📍 Dolny Śląsk</span>
    <span class="chip cs">🔧 Bez doświadczenia</span>
    <span class="chip cs">🏠 Brak wyjazdów za granicę</span>
    <span class="chip cg">🪪 Kat. B · C · D</span>
    <span class="chip cg">📅 Ostatnie 30 dni</span>
  </div>
</header>

<main>
  <div class="api-row">
    <input type="password" id="apiKey" placeholder="Klucz API Anthropic (sk-ant-…)" />
    <button class="btn-sm" onclick="toggleKey()">Pokaż</button>
  </div>

  <button class="btn-search" id="searchBtn" onclick="doSearch()">🔍 Szukaj świeżych ofert</button>

  <div class="status" id="statusBar"></div>
  <div id="errorBox"></div>
  <div id="results"></div>
</main>

<script>
const $ = id => document.getElementById(id);

try { $('apiKey').value = localStorage.getItem('ant_key') || ''; } catch(e){}
function toggleKey() {
  const k = $('apiKey');
  k.type = k.type === 'password' ? 'text' : 'password';
}
$('apiKey').addEventListener('change', () => {
  try { localStorage.setItem('ant_key', $('apiKey').value.trim()); } catch(e){}
});

function setStatus(msg, spin = false) {
  $('statusBar').innerHTML = msg ? (spin ? `<div class="spinner"></div>${msg}` : msg) : '';
}
function showError(msg) {
  $('errorBox').innerHTML = msg ? `<div class="error-box">⚠️ ${msg}</div>` : '';
}

const PROMPT = `Jesteś asystentem do wyszukiwania pracy dla Marka z Lwówka Śląskiego (Dolny Śląsk).

PROFIL:
- Mieszka w Lwówku Śląskim (pow. lwówecki, woj. dolnośląskie)
- Prawo jazdy kat. B, C i D — duże doświadczenie w prowadzeniu pojazdów
- Brak doświadczenia technicznego, ale praktyczny i chętny do nauki
- Nie chce wyjazdów zagranicznych ani tygodniowych delegacji
- Sporadyczne jednodniowe delegacje krajowe — OK
- Może dojeżdżać do bazy max 50 km od Lwówka (Jelenia Góra, Złotoryja, Bolesławiec, Lubań, Gryfów, Zgorzelec)
- Akceptuje też firmy z innych miast (Wrocław, Legnica itp.) jeśli dają auto służbowe DO DOMU i teren pracy to Dolny Śląsk

STANOWISKA (priorytet):
- Serwisant / technik terenowy (automaty vendingowe, alarmy, windy, kotły, pompy ciepła, klimatyzacje, fotowoltaika, kasy fiskalne, bankomaty, UPS-y, gaśnice, wagi, drukarki)
- Instalator (alarmy, CCTV, domofony, klimatyzacja, fotowoltaika, sieci)
- Każda rola terenowa z autem służbowym na Dolnym Śląsku

TWARDE WYMAGANIA — oferta MUSI spełniać WSZYSTKIE:
1. Auto służbowe lub auto do dyspozycji pracownika
2. Praca w terenie na Dolnym Śląsku lub baza do 50 km od Lwówka
3. NIE wymaga wcześniejszego doświadczenia technicznego (lub firma szkoli)
4. Brak stałych wyjazdów zagranicznych
5. Ogłoszenie z ostatnich 30 dni — sprawdź datę publikacji!

ODRZUĆ oferty które:
- Wymagają doświadczenia (np. "min. 2 lata w serwisie")
- Mają bazę tylko we Wrocławiu/Legnicy bez auta służbowego do domu
- Dotyczą stałej pracy za granicą lub tygodniowych tras
- Są nieaktualne (starsze niż 30 dni)

Przeszukaj DOKŁADNIE te serwisy (wyszukaj frazy po polsku):
- pracuj.pl — "serwisant auto służbowe dolny śląsk", "instalator bez doświadczenia jelenia góra"
- olx.pl/praca — "technik terenowy dolny śląsk auto"
- indeed.pl — "serwisant dolnośląskie", "instalator jelenia góra auto służbowe"
- linkedin.com/jobs — "field technician Lower Silesia", "serwisant Jelenia Góra"
- praca.pl — "serwisant auto służbowe"
- jooble.org/pl — "technik serwisu dolnośląskie"

Odpowiedz WYŁĄCZNIE poprawnym JSON, zero tekstu przed ani po:

{
  "summary": "1-2 zdania o tym co znalazłeś i dlaczego oferty pasują",
  "oferty": [
    {
      "tytul": "dokładna nazwa stanowiska",
      "firma": "nazwa firmy",
      "lokalizacja": "miasto gdzie jest baza lub teren pracy",
      "serwis": "nazwa portalu",
      "url": "BEZPOŚREDNI link do ogłoszenia — OBOWIĄZKOWY, nie strona główna portalu",
      "wynagrodzenie": "widełki lub pusty string jeśli brak",
      "delegacje": "brak / sporadyczne krajowe / inne",
      "szkolenie": "tak — firma szkoli / nie info / nie",
      "data_ogloszenia": "np. '5 dni temu' lub konkretna data",
      "dlaczego_pasuje": "1 zdanie — konkretny powód dla Marka"
    }
  ],
  "wskazowka": "1 konkretna rada jak Marek może zwiększyć szansę"
}

WAŻNE co do URL: podaj PRAWDZIWY, działający link do konkretnego ogłoszenia. Jeśli nie masz pewności co do linka — wpisz pusty string, nie wymyślaj adresów.

Zwróć 3-8 ofert które NAPRAWDĘ pasują. Lepiej 3 dobre niż 8 słabych.`;

async function doSearch() {
  const apiKey = $('apiKey').value.trim();
  if (!apiKey) { showError('Wklej klucz API Anthropic.'); return; }
  try { localStorage.setItem('ant_key', apiKey); } catch(e){}

  showError('');
  $('results').innerHTML = '';
  $('searchBtn').disabled = true;

  const msgs = [
    'Szukam świeżych ogłoszeń na Pracuj.pl…',
    'Sprawdzam OLX i Indeed…',
    'Weryfikuję wymagania i auto służbowe…',
    'Odrzucam nieaktualne i niedopasowane…',
    'Prawie gotowe…'
  ];
  let mi = 0;
  setStatus(msgs[0], true);
  const iv = setInterval(() => { mi = (mi+1) % msgs.length; setStatus(msgs[mi], true); }, 4000);

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 4000,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{
          role: 'user',
          content: PROMPT + '\n\nDzisiejsza data: ' + new Date().toLocaleDateString('pl-PL', {day:'numeric',month:'long',year:'numeric'}) + '. Szukaj tylko ogłoszeń z ostatnich 30 dni.'
        }]
      })
    });

    clearInterval(iv);

    if (!resp.ok) {
      const err = await resp.json().catch(() => ({}));
      throw new Error(err.error?.message || `HTTP ${resp.status}`);
    }

    const data = await resp.json();
    const rawText = data.content.filter(b => b.type === 'text').map(b => b.text).join('\n');

    setStatus('');

    let parsed = null;
    try {
      const clean = rawText.replace(/```json|```/g, '').trim();
      const m = clean.match(/\{[\s\S]*\}/);
      if (m) parsed = JSON.parse(m[0]);
    } catch(e) {}

    if (parsed && parsed.oferty) render(parsed);
    else $('results').innerHTML = `<div class="summary">${esc(rawText)}</div>`;

  } catch(err) {
    clearInterval(iv);
    setStatus('');
    showError(err.message || 'Błąd połączenia z API.');
  } finally {
    $('searchBtn').disabled = false;
  }
}

function render(d) {
  const wrap = $('results');
  wrap.innerHTML = '';

  if (d.summary) {
    const s = document.createElement('div');
    s.className = 'summary';
    s.textContent = d.summary;
    wrap.appendChild(s);
  }

  const hd = document.createElement('div');
  hd.className = 'results-hd';
  hd.innerHTML = `<h2>Znalezione oferty</h2><span class="badge">${d.oferty.length}</span>`;
  wrap.appendChild(hd);

  if (!d.oferty.length) {
    wrap.innerHTML += `<div class="no-results">Nie znaleziono pasujących ofert.<br>Spróbuj za kilka dni — ogłoszenia pojawiają się codziennie.</div>`;
    return;
  }

  d.oferty.forEach(o => {
    const card = document.createElement('div');
    card.className = 'offer';

    const hasLink = o.url && o.url.startsWith('http');
    const linkHTML = hasLink
      ? `<a class="offer-link" href="${esc(o.url)}" target="_blank" rel="noopener">→ Otwórz ogłoszenie na ${esc(o.serwis || 'portalu')}</a>`
      : `<span class="offer-link-missing">Link niedostępny — wyszukaj ręcznie: "${esc(o.tytul)}" + "${esc(o.firma)}"</span>`;

    card.innerHTML = `
      <div class="offer-top">
        <div class="offer-title">${esc(o.tytul)}</div>
        <span class="src">${esc(o.serwis || '—')}</span>
      </div>
      <div class="offer-company">${esc(o.firma || 'Firma nieujawniona')}</div>
      <div class="pills">
        <span class="pill p-loc">📍 ${esc(o.lokalizacja || '—')}</span>
        <span class="pill p-car">🚗 Auto służbowe</span>
        ${o.wynagrodzenie ? `<span class="pill p-pay">💰 ${esc(o.wynagrodzenie)}</span>` : ''}
        ${o.data_ogloszenia ? `<span class="pill p-date">📅 ${esc(o.data_ogloszenia)}</span>` : ''}
        ${o.delegacje ? `<span class="pill p-del">✈️ ${esc(o.delegacje)}</span>` : ''}
        ${o.szkolenie && o.szkolenie !== 'nie info' ? `<span class="pill p-train">🎓 ${esc(o.szkolenie)}</span>` : ''}
      </div>
      ${o.dlaczego_pasuje ? `<div class="offer-why">✓ ${esc(o.dlaczego_pasuje)}</div>` : ''}
      ${linkHTML}
    `;
    wrap.appendChild(card);
  });

  if (d.wskazowka) {
    const tip = document.createElement('div');
    tip.className = 'tip';
    tip.innerHTML = `<strong>💡 Wskazówka:</strong> ${esc(d.wskazowka)}`;
    wrap.appendChild(tip);
  }
}

function esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
</body>
</html>
