<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Praca dla Marka — Dolny Śląsk</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap');

:root {
  --ink:    #0d1117;
  --paper:  #f5f2eb;
  --cream:  #ede9e0;
  --rust:   #c0440a;
  --rust2:  #e05c1a;
  --steel:  #2d4a6e;
  --steel2: #3d6494;
  --muted:  #7a7060;
  --line:   #d8d2c5;
  --card:   #faf8f4;
  --green:  #2a7a4b;
  --radius: 10px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--paper);
  color: var(--ink);
  min-height: 100vh;
}

/* ── HEADER ─────────────────────────────── */
.hero {
  background: var(--ink);
  color: var(--paper);
  padding: 28px 20px 24px;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  right: -30px; top: -30px;
  width: 180px; height: 180px;
  border-radius: 50%;
  background: var(--rust);
  opacity: 0.15;
  pointer-events: none;
}

.hero-label {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--rust2);
  margin-bottom: 8px;
}

.hero h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.5rem, 7vw, 2.1rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 10px;
}

.hero h1 em {
  font-style: normal;
  color: var(--rust2);
}

.hero-sub {
  font-size: 0.85rem;
  color: #a8a098;
  line-height: 1.5;
}

/* ── PROFIL CHIPS ────────────────────────── */
.chips-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  padding: 14px 20px;
  background: var(--ink);
  border-top: 1px solid #2a2a2a;
}

.chip {
  font-size: 0.72rem;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 20px;
  letter-spacing: 0.03em;
}

.chip-rust  { background: rgba(192,68,10,0.25); color: var(--rust2); }
.chip-steel { background: rgba(45,74,110,0.4);  color: #7eb3e8; }
.chip-green { background: rgba(42,122,75,0.25); color: #5ec98a; }

/* ── MAIN ────────────────────────────────── */
main { padding: 20px 16px 60px; max-width: 700px; margin: 0 auto; }

/* ── API KEY ─────────────────────────────── */
.api-row {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
  align-items: center;
}

.api-row input {
  flex: 1;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.88rem;
  padding: 10px 13px;
  border: 1.5px solid var(--line);
  border-radius: var(--radius);
  background: var(--card);
  color: var(--ink);
  outline: none;
  transition: border-color 0.2s;
}

.api-row input:focus { border-color: var(--steel2); }

.btn-sm {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 600;
  padding: 10px 13px;
  border-radius: var(--radius);
  border: 1.5px solid var(--line);
  background: var(--card);
  color: var(--muted);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.2s;
}
.btn-sm:hover { border-color: var(--steel2); color: var(--steel); }

/* ── SEARCH BUTTON ───────────────────────── */
.search-wrap { margin-bottom: 24px; }

.btn-search {
  width: 100%;
  font-family: 'Syne', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.02em;
  padding: 16px;
  border: none;
  border-radius: var(--radius);
  background: var(--rust);
  color: #fff;
  cursor: pointer;
  transition: background 0.2s, transform 0.1s;
  position: relative;
  overflow: hidden;
}

.btn-search:hover  { background: var(--rust2); }
.btn-search:active { transform: scale(0.99); }
.btn-search:disabled { background: #bbb; cursor: not-allowed; }

/* ── STATUS ──────────────────────────────── */
.status {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 0.83rem;
  color: var(--muted);
  margin-bottom: 16px;
  min-height: 24px;
}

.spinner {
  width: 14px; height: 14px;
  border: 2px solid var(--line);
  border-top-color: var(--rust);
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── ERROR ───────────────────────────────── */
.error-box {
  background: #fff0ec;
  border: 1.5px solid #f5c2ad;
  border-radius: var(--radius);
  color: #9b3015;
  font-size: 0.84rem;
  padding: 12px 14px;
  margin-bottom: 16px;
}

/* ── SUMMARY CARD ────────────────────────── */
.summary-card {
  background: var(--steel);
  color: #dce8f5;
  border-radius: var(--radius);
  padding: 16px 18px;
  font-size: 0.86rem;
  line-height: 1.6;
  margin-bottom: 20px;
}

.summary-card strong { color: #fff; }

/* ── SECTION HEADER ──────────────────────── */
.section-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.section-hd h2 {
  font-family: 'Syne', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--muted);
}

.count-badge {
  font-size: 0.72rem;
  font-weight: 700;
  background: var(--rust);
  color: #fff;
  padding: 2px 9px;
  border-radius: 20px;
}

/* ── OFFER CARD ──────────────────────────── */
.offer {
  background: var(--card);
  border: 1.5px solid var(--line);
  border-radius: var(--radius);
  padding: 16px;
  margin-bottom: 12px;
  transition: border-color 0.2s, box-shadow 0.2s;
  position: relative;
}

.offer:hover {
  border-color: var(--rust);
  box-shadow: 0 2px 12px rgba(192,68,10,0.08);
}

.offer-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 5px;
}

.offer-title {
  font-family: 'Syne', sans-serif;
  font-size: 0.97rem;
  font-weight: 700;
  color: var(--ink);
  line-height: 1.25;
  flex: 1;
}

.source-badge {
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  background: var(--cream);
  color: var(--muted);
  flex-shrink: 0;
  border: 1px solid var(--line);
}

.offer-company {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--steel);
  margin-bottom: 8px;
}

.offer-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 14px;
  font-size: 0.78rem;
  color: var(--muted);
  margin-bottom: 10px;
}

.meta-item { display: flex; align-items: center; gap: 4px; }

.salary { color: var(--green); font-weight: 700; }
.car-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--rust);
  background: rgba(192,68,10,0.08);
  border: 1px solid rgba(192,68,10,0.2);
  padding: 2px 8px;
  border-radius: 4px;
}

.offer-desc {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.55;
  margin-bottom: 10px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--line);
}

.offer-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
}

.offer-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.tag {
  font-size: 0.7rem;
  padding: 2px 8px;
  border-radius: 4px;
  background: var(--cream);
  color: var(--muted);
  border: 1px solid var(--line);
}

.offer-link {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--rust);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  transition: opacity 0.15s;
  flex-shrink: 0;
}
.offer-link:hover { opacity: 0.7; }

/* ── TIP ─────────────────────────────────── */
.tip-card {
  margin-top: 20px;
  border-left: 3px solid var(--rust);
  padding: 12px 14px;
  background: var(--cream);
  border-radius: 0 var(--radius) var(--radius) 0;
  font-size: 0.83rem;
  color: var(--muted);
  line-height: 1.55;
}

.tip-card strong { color: var(--ink); }

/* ── EMPTY ───────────────────────────────── */
.empty {
  text-align: center;
  padding: 48px 20px;
  color: var(--muted);
  font-size: 0.88rem;
  line-height: 1.6;
}

/* ── DIVIDER ─────────────────────────────── */
hr { border: none; border-top: 1px solid var(--line); margin: 0 0 20px; }
</style>
</head>
<body>

<header>
  <div class="hero">
    <div class="hero-label">Dolny Śląsk · okolice Lwówka Śląskiego</div>
    <h1>Praca<br>z <em>autem służbowym</em></h1>
    <p class="hero-sub">Serwisant · Instalator · Technik terenowy<br>Firmy szukające pracowników w Twoim regionie</p>
  </div>
  <div class="chips-bar">
    <span class="chip chip-rust">🚗 Auto służbowe</span>
    <span class="chip chip-rust">📍 Do 50 km od bazy</span>
    <span class="chip chip-steel">🔧 Bez wymaganego doświadczenia</span>
    <span class="chip chip-steel">🏠 Brak wyjazdów zagranicznych</span>
    <span class="chip chip-green">🪪 Kat. B · C · D</span>
    <span class="chip chip-green">Dolny Śląsk</span>
  </div>
</header>

<main>

  <div class="api-row">
    <input type="password" id="apiKey" placeholder="Klucz API Anthropic (sk-ant-…)" />
    <button class="btn-sm" onclick="toggleKey()">Pokaż</button>
  </div>

  <div class="search-wrap">
    <button class="btn-search" id="searchBtn" onclick="doSearch()">
      🔍 Szukaj ofert teraz
    </button>
  </div>

  <div class="status" id="statusBar"></div>
  <div id="errorBox"></div>
  <div id="results"></div>

</main>

<script>
const $ = id => document.getElementById(id);

// Klucz API — zapamiętaj
function toggleKey() {
  const k = $('apiKey');
  k.type = k.type === 'password' ? 'text' : 'password';
}
try { $('apiKey').value = localStorage.getItem('ant_key') || ''; } catch(e){}
$('apiKey').addEventListener('change', () => {
  try { localStorage.setItem('ant_key', $('apiKey').value.trim()); } catch(e){}
});

function setStatus(msg, spin = false) {
  $('statusBar').innerHTML = msg
    ? (spin ? `<div class="spinner"></div>${msg}` : msg)
    : '';
}
function showError(msg) {
  $('errorBox').innerHTML = msg
    ? `<div class="error-box">⚠️ ${msg}</div>` : '';
}

// ── Prompt skrojony pod Marka ─────────────────────────────────────────────
const SYSTEM_PROMPT = `Jesteś specjalistycznym asystentem do wyszukiwania pracy dla Marka — mieszkańca Lwówka Śląskiego (Dolny Śląsk, Polska).

PROFIL UŻYTKOWNIKA:
- Mieszka w Lwówku Śląskim, powiat lwówecki, woj. dolnośląskie
- Prawo jazdy: kat. B, C i D (duże doświadczenie w prowadzeniu pojazdów)
- Brak doświadczenia technicznego, ale jest praktyczny i chętny do nauki
- Nie może pracować fizycznie wyczerpująco
- NIE chce wyjazdów zagranicznych ani tygodniowych delegacji w trasie
- Sporadyczne jednodniowe delegacje krajowe są OK
- Baza/siedziba firmy: do 50 km od Lwówka Śląskiego (np. Jelenia Góra, Złotoryja, Bolesławiec, Zgorzelec, Gryfów Śląski, Lubań)
- Alternatywnie: firmy z innych miast (np. Wrocław, Legnica), które obsługują region Dolnego Śląska i dają auto służbowe do dojazdów z domu

POSZUKIWANE STANOWISKA (priorytetowo):
1. Serwisant / technik terenowy (urządzenia, maszyny, systemy — np. automaty vendingowe, systemy alarmowe, dźwigi, klimatyzacje, kotły, pompy ciepła, fotowoltaika, kasy fiskalne, bankomaty)
2. Instalator (alarmy, CCTV, klimatyzacja, fotowoltaika, sieci, domofony)
3. Technik serwisu z obsługą klienta
4. Każda inna rola z autem służbowym i pracą w terenie na Dolnym Śląsku

WYMAGANIA BEZWZGLĘDNE w każdej ofercie:
- Samochód służbowy (auto do dojazdów do klientów lub do dyspozycji)
- Brak wymaganego doświadczenia technicznego (lub firma szkoli od podstaw)
- Praca na Dolnym Śląsku / w regionie Lwówka Śląskiego
- Brak stałych wyjazdów zagranicznych

Przeszukaj polskie serwisy ogłoszeniowe: Pracuj.pl, OLX Praca, Indeed Polska, LinkedIn, Praca.pl, GoWork.pl, Aplikuj.pl, Jooble.

Odpowiedz WYŁĄCZNIE poprawnym JSON, zero tekstu przed ani po:

{
  "summary": "2-3 zdania o sytuacji na rynku dla tego profilu w regionie",
  "oferty": [
    {
      "tytul": "dokładna nazwa stanowiska z ogłoszenia",
      "firma": "nazwa firmy",
      "lokalizacja": "miasto, województwo",
      "baza": "gdzie jest siedziba / skąd wychodzi trasa",
      "serwis": "nazwa portalu z ogłoszeniem",
      "url": "link do ogłoszenia lub pusty string",
      "wynagrodzenie": "widełki lub pusty string",
      "typ_umowy": "UoP / B2B / UZ / inny",
      "auto_sluzbowe": true,
      "delegacje": "opis charakteru delegacji (np. brak, sporadyczne krajowe, itp.)",
      "szkolenie": "czy firma szkoli — tak/nie/brak info",
      "opis": "2-3 zdania o obowiązkach i czego szukają",
      "dlaczego_pasuje": "1 zdanie dlaczego ta oferta pasuje dla Marka",
      "tagi": ["tag1", "tag2"],
      "data": "kiedy dodano np. 2 dni temu lub pusty string"
    }
  ],
  "wskazowka": "1 konkretna praktyczna rada dla Marka jak zwiększyć szansę na tę pracę",
  "alternatywy": "jeśli mało wyników — jakich słów kluczowych szukać samodzielnie"
}

Zwróć 3-10 ofert. Jeśli nie ma dokładnych trafień dla Lwówka, szukaj firm z Dolnego Śląska dających auto służbowe pracownikom terenowym.`;

async function doSearch() {
  const apiKey = $('apiKey').value.trim();
  if (!apiKey) { showError('Wklej klucz API Anthropic.'); return; }

  try { localStorage.setItem('ant_key', apiKey); } catch(e){}

  showError('');
  $('results').innerHTML = '';
  $('searchBtn').disabled = true;

  const steps = [
    'Szukam ofert serwisanta i instalatora…',
    'Przeszukuję Pracuj.pl, OLX, Indeed…',
    'Sprawdzam wymagania i auta służbowe…',
    'Filtruję pod Twój profil…',
    'Prawie gotowe…'
  ];
  let si = 0;
  setStatus(steps[0], true);
  const iv = setInterval(() => {
    si = (si + 1) % steps.length;
    setStatus(steps[si], true);
  }, 3500);

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-6',
        max_tokens: 4000,
        system: SYSTEM_PROMPT,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{
          role: 'user',
          content: 'Znajdź aktualne oferty pracy pasujące do mojego profilu. Dzisiejsza data: ' + new Date().toLocaleDateString('pl-PL') + '. Szukaj najświeższych ogłoszeń.'
        }]
      })
    });

    clearInterval(iv);

    if (!resp.ok) {
      const err = await resp.json().catch(() => ({}));
      throw new Error(err.error?.message || `HTTP ${resp.status}`);
    }

    const data = await resp.json();
    const rawText = data.content
      .filter(b => b.type === 'text')
      .map(b => b.text)
      .join('\n');

    setStatus('');

    let parsed = null;
    try {
      const clean = rawText.replace(/```json|```/g, '').trim();
      const m = clean.match(/\{[\s\S]*\}/);
      if (m) parsed = JSON.parse(m[0]);
    } catch(e) {}

    if (parsed && parsed.oferty) {
      render(parsed);
    } else {
      $('results').innerHTML = `<div class="summary-card" style="white-space:pre-wrap">${esc(rawText)}</div>`;
    }

  } catch(err) {
    clearInterval(iv);
    setStatus('');
    showError(err.message || 'Błąd połączenia z API.');
  } finally {
    $('searchBtn').disabled = false;
  }
}

function render(d) {
  const wrap = $('results');
  wrap.innerHTML = '';

  // Podsumowanie
  if (d.summary) {
    const s = document.createElement('div');
    s.className = 'summary-card';
    s.innerHTML = d.summary;
    wrap.appendChild(s);
  }

  // Nagłówek sekcji
  const hd = document.createElement('div');
  hd.className = 'section-hd';
  hd.innerHTML = `<h2>Znalezione oferty</h2><span class="count-badge">${d.oferty.length}</span>`;
  wrap.appendChild(hd);

  // Karty ofert
  d.oferty.forEach(o => {
    const card = document.createElement('div');
    card.className = 'offer';

    const tagiHTML = (o.tagi || []).map(t => `<span class="tag">${esc(t)}</span>`).join('');
    const linkHTML = o.url
      ? `<a class="offer-link" href="${esc(o.url)}" target="_blank" rel="noopener">Ogłoszenie ↗</a>`
      : '';

    card.innerHTML = `
      <div class="offer-head">
        <div class="offer-title">${esc(o.tytul || '—')}</div>
        <span class="source-badge">${esc(o.serwis || '—')}</span>
      </div>
      <div class="offer-company">${esc(o.firma || 'Firma nieujawniona')}</div>
      <div class="offer-meta">
        <span class="meta-item">📍 ${esc(o.lokalizacja || '—')}</span>
        ${o.baza ? `<span class="meta-item">🏢 baza: ${esc(o.baza)}</span>` : ''}
        ${o.typ_umowy ? `<span class="meta-item">📄 ${esc(o.typ_umowy)}</span>` : ''}
        ${o.data ? `<span class="meta-item">🕐 ${esc(o.data)}</span>` : ''}
        ${o.wynagrodzenie ? `<span class="meta-item salary">💰 ${esc(o.wynagrodzenie)}</span>` : ''}
      </div>
      ${o.auto_sluzbowe ? `<span class="car-badge">🚗 Auto służbowe</span>&nbsp;` : ''}
      ${o.delegacje ? `<span class="tag">✈️ ${esc(o.delegacje)}</span>` : ''}
      ${o.szkolenie && o.szkolenie !== 'brak info' ? `<span class="tag" style="margin-left:4px">🎓 Szkolenie: ${esc(o.szkolenie)}</span>` : ''}
      <br><br>
      <div class="offer-desc">${esc(o.opis || '')}</div>
      ${o.dlaczego_pasuje ? `<div style="font-size:0.78rem;color:var(--rust);font-weight:600;margin-bottom:10px">✓ ${esc(o.dlaczego_pasuje)}</div>` : ''}
      <div class="offer-footer">
        <div class="offer-tags">${tagiHTML}</div>
        ${linkHTML}
      </div>
    `;
    wrap.appendChild(card);
  });

  // Wskazówka
  if (d.wskazowka) {
    const tip = document.createElement('div');
    tip.className = 'tip-card';
    tip.innerHTML = `<strong>💡 Wskazówka:</strong> ${esc(d.wskazowka)}`;
    wrap.appendChild(tip);
  }

  // Alternatywy
  if (d.alternatywy) {
    const alt = document.createElement('div');
    alt.className = 'tip-card';
    alt.style.marginTop = '10px';
    alt.innerHTML = `<strong>🔎 Szukaj też:</strong> ${esc(d.alternatywy)}`;
    wrap.appendChild(alt);
  }
}

function esc(s) {
  if (!s) return '';
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}
</script>
</body>
</html>
